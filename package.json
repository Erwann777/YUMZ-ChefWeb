{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npx tailwindcss -i resources/css/app.css -o resources/css/compiled.css --minify && vite build",
        "dev": "concurrently \"npx tailwindcss -i resources/css/app.css -o resources/css/compiled.css --watch\" \"vite\""
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "vite": "^7.0.7"
    }
}
